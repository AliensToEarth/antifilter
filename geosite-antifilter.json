{
    "input": [
        {
            "type": "readGeoSiteDat",
            "action": "add",
            "args": {
                "path": "../output/geosite.dat"
            }
        }
    ],
    "output": [
        {
            "type": "v2rayGeoSiteDat",
            "action": "output",
            "args": {
                "outputDir": "../output",
                "outputName": "geosite-antifilter.dat",
                "wantedList": [
                    "adobe",
                    "autodesk",
                    "twitter",
                    "google",
                    "youtube",
                    "spotify",
                    "tidal",
                    "twitch",
                    "meta",
                    "telegram",
                    "openai",
                    "anthropic",
                    "deepseek",
                    "sony",
                    "github",
                    "npmjs",
                    "slack",
                    "discord",
                    "lenovo",
                    "antifilter-community",
                    "private"
                ]
            }
        }
    ]
}